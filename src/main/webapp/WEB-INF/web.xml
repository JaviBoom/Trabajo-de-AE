<?xml version="1.0" encoding="UTF-8"?>
<web-app version="3.1" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_3_1.xsd">
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.example.proyecto_ae.servlets.auth.LoginServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>CallbackServlet</servlet-name>
        <servlet-class>com.example.proyecto_ae.servlets.auth.CallbackServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FirmaServlet</servlet-name>
        <servlet-class>com.example.proyecto_ae.servlets.firma.FirmaServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>FirmaCallbackServlet</servlet-name>
        <servlet-class>com.example.proyecto_ae.servlets.firma.FirmaCallbackServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>DescargarPdfFirmadoServlet</servlet-name>
        <servlet-class>com.example.proyecto_ae.servlets.firma.DescargarPdfFirmadoServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>CallbackServlet</servlet-name>
        <url-pattern>/CallbackServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FirmaServlet</servlet-name>
        <url-pattern>/FirmaServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>FirmaCallbackServlet</servlet-name>
        <url-pattern>/FirmaCallbackServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>DescargarPdfFirmadoServlet</servlet-name>
        <url-pattern>/DescargarPdfFirmadoServlet</url-pattern>
    </servlet-mapping>
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
